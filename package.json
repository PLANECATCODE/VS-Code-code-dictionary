{
  "name": "code-dictionary",
  "displayName": "Code Dictionary",
  "description": "Searchable dictionary for Python, C++, JS, HTML, Java",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-dictionary.search",
        "title": "Code Dictionary: Search"
      }
    ],
    "keybindings": [
      {
        "command": "code-dictionary.search",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}